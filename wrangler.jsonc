{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "remote-control-ui",
  "compatibility_date": "2026-05-05",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./public"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "kv_namespaces": [
    {
      "binding": "LOCATION_KV",
      "id": "placeholder_id" 
    }
  ]
}
