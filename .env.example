# Local Environment Variables for wrangler dev
# Copy this file to .env and fill in your actual values.
# .env is gitignored and will not be committed.

# The primary password required to log in to the dashboard
ACCESS_KEY=your_access_key_here

# Secret token required by MacroDroid to authorize status updates and uploads
REPORT_KEY=your_report_key_here

# Secondary passcode required to authorize access to encrypted vault routes
VAULT_PASS=your_vault_pass_here

# The unique target ID of the device's MacroDroid webhook trigger
MACRO_ID=your_macro_id_here

# Private key for signing and verifying JWT session cookies (Optional)
# JWT_SECRET=your_jwt_secret_here
